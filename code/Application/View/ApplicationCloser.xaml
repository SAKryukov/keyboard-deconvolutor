<Popup x:Class="SA.ApplicationCloser"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:system="clr-namespace:System;assembly=netstandard"        
        xmlns:controls="clr-namespace:SA.Controls">
  <Popup.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="Padding" Value="12, 0, 12, 0"/>
    </Style>
    <Style x:Key="legendTextBlock" TargetType="TextBlock">
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="Foreground" Value="Yellow"/>
    </Style>
    <Style x:Key="legend" TargetType="Border">
      <Setter Property="Padding" Value="0, 4, 0, 20"/>
      <Setter Property="Background" Value="Blue"/>
    </Style>
  </Popup.Resources>
  <Border Background="White" BorderBrush="Black" BorderThickness="2">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Border Style="{StaticResource legend}">
        <TextBlock Style="{StaticResource legendTextBlock}" x:Name="textBlock" Grid.Row="0">Mapping is modified</TextBlock>
      </Border>
      <ListBox x:Name="listBox" Grid.Row="1" SelectedIndex="2" FocusVisualStyle="{x:Null}">
        <ListBoxItem Content="Quit without saving"/>
        <ListBoxItem IsSelected="true" Content="Store mapping"/>
        <ListBoxItem Content="Store mapping and quit"/>
      </ListBox>  
    </Grid>
  </Border>
</Popup>

<Window x:Class="SA.WindowMain"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:system="clr-namespace:System;assembly=netstandard"
        xmlns:controls="clr-namespace:SA.Controls"
        MinWidth="600"
        MinHeight="800"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        FontSize="{DynamicResource fontSizeDefault}"
        ResizeMode="CanResizeWithGrip">

  <Window.Resources>
    <Thickness x:Key="statusBarItemMargin">8 0 20 0</Thickness>
    <system:Double x:Key="fontSizeDefault">18</system:Double>
    <Style x:Key="focusRectangle">
      <Setter Property="Control.Template">
        <Setter.Value>
          <ControlTemplate>
            <Rectangle Stroke="Green"
                       StrokeThickness="2"
                       SnapsToDevicePixels="True"
                       Margin="-4"/>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="Button">
      <Setter Property="Width" Value="Auto"/>
      <Setter Property="Padding" Value="8, 2, 8, 2"/>
      <Setter Property="Background" Value="SeaShell"/>
      <Setter Property="FocusVisualStyle" Value="{StaticResource focusRectangle}"/>
    </Style>
    <Style TargetType="CheckBox">
      <Setter Property="FocusVisualStyle" Value="{StaticResource focusRectangle}"/>
    </Style>
    <Style TargetType="controls:Arrow">
      <Setter Property="Margin" Value="0, 4, 0, 8"/>
      <Setter Property="FocusVisualStyle" Value="{StaticResource focusRectangle}"/>
    </Style>
    <Style x:Key="spacer" TargetType="TextBlock">
      <Setter Property="Width" Value="8"/>
    </Style>
    <DataTemplate x:Key="comboBoxItemTemplate">
      <Grid Margin="2,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/> <!-- Scan code -->
          <ColumnDefinition Width="*"/> <!-- Human-Readable Name -->
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0"
          Text="{Binding ScanCode}"
          FontFamily="Consolas, Courier New, Global Monospace"
          FontWeight="Bold"
          Foreground="Blue"
          VerticalAlignment="Bottom"/>
        <TextBlock Grid.Column="1"
          Text="{Binding Name}"
          FontWeight="SemiBold"
          VerticalAlignment="Bottom"
          Margin="8,0,0,0"/>
      </Grid>
    </DataTemplate>
    <Style x:Key="comboBoxContainerStyle"
        TargetType="{x:Type ComboBoxItem}">
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="Padding" Value="4,0,4,0"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="LightBlue"/>
        </Trigger>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#FFE0F2F1"/>
          <Setter Property="Foreground" Value="Black"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style TargetType="ComboBox"> <!-- should be below comboBoxItemTemplate and comboBoxContainerStyle -->
      <Setter Property="ItemTemplate" Value="{StaticResource comboBoxItemTemplate}"/>
      <Setter Property="ItemContainerStyle" Value="{StaticResource comboBoxContainerStyle}"/>
      <Setter Property="FocusVisualStyle" Value="{StaticResource focusRectangle}"/>
      <Setter Property="IsTextSearchEnabled" Value="True"/>
      <Setter Property="TextSearch.TextPath" Value="Name"/>
      <Setter Property="IsEditable" Value="False"/>
      <Setter Property="Height" Value="Auto"/>
      <Setter Property="SelectedIndex" Value="0"/>
    </Style>
    <Style TargetType="GridViewColumnHeader">
      <Setter Property="Padding" Value="16,4,16,4" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Background" Value="#F5F5F5"/>
      <Setter Property="BorderBrush" Value="LightGray"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/> 
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="GridViewColumnHeader">
            <Border BorderThickness="{TemplateBinding BorderThickness}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="ListViewItem">
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="SnapsToDevicePixels" Value="True"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListViewItem">
            <!-- Horizontal gridlines only via the bottom border -->
            <Border x:Name="ItemBorder"
                    Background="Transparent"
                    BorderBrush="LightGray"
                    BorderThickness="0,0,0,1"
                    Padding="16,0,16,0">        
              <GridViewRowPresenter x:Name="Presenter" 
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
            </Border>       
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ItemBorder" Property="Background" Value="#F2F2F2"/>
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="ItemBorder" Property="Background" Value="#FF0078D7"/>
                <Setter Property="Foreground" Value="White"/>
              </Trigger>
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="IsSelected" Value="True"/>
                  <Condition Property="IsFocused" Value="False"/>
                </MultiTrigger.Conditions>
                <Setter TargetName="ItemBorder" Property="Background" Value="#CCE4F7"/>
                <Setter Property="Foreground" Value="Black"/>
              </MultiTrigger>
            </ControlTemplate.Triggers>
              </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Window.ContextMenu>
    <ContextMenu FontSize="20" StaysOpen="true">
      <MenuItem Header="Open..." Command="ApplicationCommands.Open">
        <MenuItem.Icon><TextBlock FontSize="16">䷉</TextBlock></MenuItem.Icon>
      </MenuItem>
      <MenuItem Header="Save" Command="ApplicationCommands.Save">
        <MenuItem.Icon><TextBlock FontSize="12">💰</TextBlock></MenuItem.Icon>
      </MenuItem>
      <MenuItem Header="Save As..." Command="ApplicationCommands.SaveAs">
      </MenuItem>
      <Separator/>
      <MenuItem Header="Help..." Command="ApplicationCommands.Help">
        <MenuItem.Icon><TextBlock FontSize="12" FontWeight="ExtraBold" Foreground="Green">❓</TextBlock></MenuItem.Icon>
      </MenuItem>
      <Separator/>
      <MenuItem Header="Quit"
        Command="ApplicationCommands.Close">
        <MenuItem.Icon><TextBlock FontSize="12" Foreground="Red">❌</TextBlock></MenuItem.Icon>
      </MenuItem>
    </ContextMenu>
  </Window.ContextMenu>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Grid Grid.Column="0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1*"/>
        <ColumnDefinition Width="1*"/>
        <ColumnDefinition Width="1*"/>
      </Grid.ColumnDefinitions>
      <Border Grid.Row="0" Grid.ColumnSpan="3">
        <controls:Keyboard x:Name="keyboard" Margin="4"/>
      </Border>
      <Border Grid.Row="1" Grid.Column="0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <controls:Arrow x:Name="arrowOriginal" Width="30" HorizontalAlignment="Center" />
          <TextBlock Grid.Row="1" HorizontalAlignment="Center" Margin="0 0 0 4">Original Scan Code:</TextBlock>
          </Grid>
      </Border>
      <Border Grid.Row="1" Grid.Column="1">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
          <CheckBox x:Name="checkBoxHardware" VerticalAlignment="Center" IsChecked = "true"/>
          <TextBlock Style="{StaticResource spacer}"/>
          <TextBlock VerticalAlignment="Center">Record keyboard events</TextBlock>
        </StackPanel>
      </Border>
      <Border Grid.Row="1" Grid.Column="2">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <controls:Arrow x:Name="arrowReplacement" Width="30" HorizontalAlignment="Center" />
          <TextBlock Grid.Row="1" HorizontalAlignment="Center" Margin="0 0 0 4">Replacement Scan Code:</TextBlock>
          </Grid>
      </Border>
      <Border Grid.Row="2" Grid.Column="0" Padding="4, 0, 0, 4">
        <ComboBox x:Name="comboBoxOriginalSelector"/>
      </Border>
      <Border Grid.Row="2" Grid.Column="1" Padding="0, 0, 0, 4">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
          <Button x:Name="buttonAdd" Command="ApplicationCommands.New">_Add</Button>
          <TextBlock Style="{StaticResource spacer}"/>
          <Button x:Name="buttonRemove" Command="EditingCommands.Delete">_Remove</Button>
        </StackPanel>
      </Border>
      <Border Grid.Row="2" Grid.Column="2" Padding="0, 0, 4, 4">
        <ComboBox x:Name="comboBoxReplacementSelector"/>
      </Border>
    </Grid>
    <Border Grid.Column="1" BorderThickness="1,0,0,0" BorderBrush="Gray">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Background="LightGray" Padding="35 7 1 6" FontWeight="SemiBold">Scan Code Map</TextBlock>
        <TextBlock Grid.Column="1" x:Name="menuStart" ToolTip="Context file menu" Background="White" FontSize="24" FontWeight="ExtraBold" Padding="16 4 16 4" HorizontalAlignment="Right">⋮</TextBlock>
        <ListView Grid.Row="1" Grid.ColumnSpan="2" x:Name="map"
                  SelectionMode="Single"
                  FocusVisualStyle="{x:Null}"
                  BorderThickness="0"
                  SnapsToDevicePixels="True">
          <ListView.View>
            <GridView>
              <GridViewColumn Header="Original" DisplayMemberBinding="{Binding Original}"/>
              <GridViewColumn Header="Replacement" DisplayMemberBinding="{Binding Replacement}"/>
            </GridView>
          </ListView.View>        
        </ListView>
        </Grid>
    </Border>
    <Border Grid.Row="1" Grid.ColumnSpan="3" BorderBrush="Gray" BorderThickness="0, 1, 0, 0">
      <StatusBar FontSize="{StaticResource fontSizeDefault}">
        <StatusBarItem HorizontalAlignment="Left">
          <TextBlock x:Name="issue" Margin="{StaticResource statusBarItemMargin}" Foreground="Red" FontWeight="Bold"/>
        </StatusBarItem>
        <StatusBarItem HorizontalAlignment="Right">
          <TextBlock x:Name="status" Margin="{StaticResource statusBarItemMargin}">Mapping</TextBlock>
        </StatusBarItem>
      </StatusBar>
    </Border>
  </Grid>

</Window>

<Window x:Class="SA.About"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:system="clr-namespace:System;assembly=netstandard"
        xmlns:controls="clr-namespace:SA.Controls"
        Width="570"
        Height="330"
        FontSize="20"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

  <Window.Resources>    
    <Thickness x:Key="paddingButton">24 0 24 0</Thickness>
    <Thickness x:Key="marginButton">8</Thickness>
    <Thickness x:Key="paddingLeft">12 12 6 12</Thickness>
    <Thickness x:Key="paddingRight">6 12 12 12</Thickness>
    <Thickness x:Key="paddingAnchors">12 8 12 8</Thickness>
    <Style x:Key="focusRectangle">
      <Setter Property="Control.Template">
        <Setter.Value>
          <ControlTemplate>
            <Rectangle Margin="3"
                       Stroke="DarkViolet"
                       StrokeThickness="2"
                       RadiusX="6" RadiusY="6"
                       SnapsToDevicePixels="True"/>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="anchorFocusRectangle" BasedOn="{StaticResource focusRectangle}">
      <Setter Property="Control.Margin" Value="-12 -3 -12 -6"/>
    </Style>
    <Style TargetType="Rectangle">
      <Setter Property="RadiusX" Value="8"/>
      <Setter Property="RadiusY" Value="8"/>
      <Setter Property="Stroke" Value="Black"/>
      <Setter Property="StrokeThickness" Value="2"/>
    </Style>
    <Style TargetType="Path">
      <Setter Property="Stroke" Value="Red"/>
      <Setter Property="StrokeThickness" Value="4"/>
    </Style>
    <Style TargetType="Button">
      <Setter Property="Template">        
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border BorderThickness="2"
                    BorderBrush="DarkGray"
                    Padding="{StaticResource paddingButton}"
                    Margin="{StaticResource marginButton}"
                    Background="{TemplateBinding Background}"
                    CornerRadius="4">
              <ContentPresenter HorizontalAlignment="Center"
                  VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="buttonFlow" TargetType="Button">
      <Setter Property="FocusVisualStyle" Value="{StaticResource anchorFocusRectangle}"/>
      <Setter Property="Padding" Value="8 2 8 2"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="Foreground" Value="Blue"/>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Border Grid.Row="0" Grid.Column="0" Padding="{StaticResource paddingLeft}">
      <Viewbox>
        <Canvas UseLayoutRounding="False"
            Width="175.75081"
            Height="133.00308">
          <Canvas.Clip>
            <RectangleGeometry Rect="0.0,0.0,175.75081,133.00308"/>
          </Canvas.Clip>
          <Canvas UseLayoutRounding="False"
              RenderTransform="1.0,0.0,0.0,1.0,-96.613262,-99.453941">
            <Canvas>
              <Rectangle Canvas.Left="108.38203"
                  Canvas.Top="168.79999"
                  Width="57.0"
                  Height="57.0"/>
              <Rectangle Canvas.Left="180.36407"
                  Canvas.Top="101.45394"
                  Width="90.0"
                  Height="57.0"/>
            </Canvas>
            <Canvas>
              <!-- Arrow: -->
              <Path Fill="#ff008600" StrokeThickness="0">
                <Path.Data>
                  <PathGeometry Figures="m 225.915 126.145 l 7.92271 5.86535 l -81.4026 50.3431 l 4.81724 7.78929 l 81.4026 -50.3432 l 1.70878 9.70834 L 250.979 125 Z"/>
                </Path.Data>
              </Path>
              <Path>
                <Path.Data>
                  <PathGeometry Figures="m 114.508 155.543 l 63.982 74.9141"/>
                </Path.Data>
              </Path>
              <Path>
                <Path.Data>
                  <PathGeometry Figures="M 170.083 157.401 L 98.6133 207.887"/>
                </Path.Data>
              </Path>
            </Canvas>
          </Canvas>
        </Canvas>
      </Viewbox>
    </Border>
    <Border Grid.Row="0" Grid.Column="1" Padding="{StaticResource paddingRight}">
      <TextBlock TextWrapping="Wrap" x:Name="description"/>
    </Border>
    <Border Grid.Row="1" Grid.ColumnSpan="2" Padding="{StaticResource paddingAnchors}">
      <StackPanel Orientation="Horizontal">
        <Button x:Name="buttonDetailedHelp" Style="{StaticResource buttonFlow}" HorizontalAlignment="Left">
          <TextBlock TextDecorations="Underline">Help</TextBlock>
        </Button>
        <Button x:Name="buttonSourceCode" Style="{StaticResource buttonFlow}" HorizontalAlignment="Left" Margin="18,0,0,0">
          <TextBlock TextDecorations="Underline">Source Code</TextBlock>
        </Button>
      </StackPanel>
    </Border>
    <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" BorderBrush="Gray" Background="#dddddd" BorderThickness="0 1 0 0">
      <Button Grid.Row="1"
        x:Name="buttonClose"
        FocusVisualStyle="{StaticResource focusRectangle}"
        Background="White"
        Width="Auto"
        Height="Auto"
        HorizontalAlignment="Center"
        IsCancel="true" IsDefault="true">Close</Button>
    </Border>
  </Grid>

</Window>
